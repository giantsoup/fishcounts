{
    "schema_version": 1,
    "corpus_version": "phase-0-v1",
    "review_status": "manually_reviewed",
    "corpus_approval": "pending_user_review",
    "metrics_definition_status": "manually_reviewed_pending_user_approval",
    "scope": "new_payloads_first",
    "architecture_decisions": {
        "delivery": "one_pull_request_and_approval_per_phase",
        "fallback": "non_blocking",
        "external_clients": "laravel_http_client_without_provider_sdks",
        "reviewer_role": "administrator",
        "shareable_data": [
            "public_fish_count_text",
            "public_source_url"
        ],
        "sharing_approval": {
            "openai": "public_fish_count_text_and_public_source_url_only",
            "local_diagnostics": "public_fish_count_text_and_public_source_url_only",
            "github_issues": "public_fish_count_text_and_public_source_url_only"
        },
        "excluded_data": [
            "html",
            "cookies",
            "request_headers",
            "credentials",
            "unrelated_page_content",
            "private_user_data"
        ],
        "historical_scope": "after_shadow_validation",
        "parser_version_source": "explicit_parsed_report_metadata",
        "confidence_policy": "measured_results_not_model_self_report",
        "additional_known_failures": "none_beyond_existing_examples",
        "fixtures_commit_safe": true,
        "phase_zero_implementation_authorized": true
    },
    "shadow_metrics": {
        "diagnostic_recall": {
            "numerator": "known_defects_with_expected_diagnostic_detected",
            "denominator": "known_defect_fixtures_reviewed",
            "unit": "ratio",
            "direction": "maximize",
            "quality_gate": "set_after_baseline"
        },
        "clean_false_positive_rate": {
            "numerator": "clean_reports_with_any_diagnostic",
            "denominator": "clean_report_fixtures_reviewed",
            "unit": "ratio",
            "direction": "minimize",
            "quality_gate": "set_after_baseline"
        },
        "human_classification_agreement": {
            "numerator": "reviewed_recommendations_matching_expected_classification_and_correction",
            "denominator": "recommendations_human_reviewed",
            "unit": "ratio",
            "direction": "maximize",
            "quality_gate": "set_after_baseline"
        },
        "invalid_schema_rate": {
            "numerator": "provider_results_rejected_by_schema_validation",
            "denominator": "provider_results_received",
            "unit": "ratio",
            "direction": "minimize",
            "quality_gate": "set_after_baseline"
        },
        "invalid_canonical_id_rate": {
            "numerator": "schema_valid_results_with_unknown_or_inactive_canonical_ids",
            "denominator": "schema_valid_results_referencing_canonical_ids",
            "unit": "ratio",
            "direction": "minimize",
            "quality_gate": "set_after_baseline"
        },
        "average_latency": {
            "numerator": "sum_of_completed_review_latency_milliseconds",
            "denominator": "completed_provider_reviews",
            "unit": "milliseconds",
            "direction": "minimize",
            "quality_gate": "baseline_only"
        },
        "average_token_cost": {
            "numerator": "sum_of_input_and_output_token_cost_usd",
            "denominator": "completed_provider_reviews",
            "unit": "usd_per_review",
            "direction": "minimize",
            "quality_gate": "baseline_only"
        }
    },
