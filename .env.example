APP_NAME=FishCounts
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

FISH_ADMIN_NAME="Fish Counts Admin"
FISH_ADMIN_EMAIL=admin@example.com
FISH_ADMIN_PASSWORD=password
FISH_SCRAPER_USER_AGENT="FishCountsBot/1.0 (+https://fish.tayloroyer.com/contact)"
FISH_CONDITIONS_LOCATION_PROFILE=san_diego_bight
FISH_CONDITIONS_TIMEZONE=America/Los_Angeles
FISH_CONDITIONS_LATITUDE=32.75
FISH_CONDITIONS_LONGITUDE=-117.25
FISH_CONDITIONS_CORONADO_LATITUDE=32.52
FISH_CONDITIONS_CORONADO_LONGITUDE=-117.43
FISH_CONDITIONS_USER_AGENT="${FISH_SCRAPER_USER_AGENT}"
FISH_CONDITIONS_TIMEOUT=20
FISH_CONDITIONS_CONNECT_TIMEOUT=10
FISH_SUSPICIOUS_PARSE_DIAGNOSTICS=false
FISH_DIAGNOSTIC_PARAGRAPH_MAX_LENGTH=2000
FISH_AI_REVIEW_ENABLED=false
FISH_AI_REVIEW_DISPATCH_ENABLED=false
FISH_AI_REVIEW_PROVIDER=openai
FISH_AI_REVIEW_MODEL=gpt-5.6-luna
FISH_AI_REVIEW_REASONING_EFFORT=medium
FISH_AI_REVIEW_CONNECT_TIMEOUT=10
FISH_AI_REVIEW_TIMEOUT=60
FISH_AI_REVIEW_PROMPT_VERSION=v1
FISH_AI_REVIEW_SCHEMA_VERSION=v1
FISH_AI_REVIEW_MAX_CANDIDATES=100
FISH_AI_REVIEW_MAX_INPUT_TOKENS=12000
FISH_AI_REVIEW_MAX_OUTPUT_TOKENS=2000
FISH_AI_REVIEW_MAX_CORRECTIONS=20
FISH_AI_REVIEW_MAX_RATIONALE_LENGTH=2000
FISH_AI_REVIEW_MAX_FAILURE_MESSAGE_LENGTH=1000
FISH_AI_REVIEW_MINIMUM_ACTIONABLE_CONFIDENCE=0.75
FISH_AI_REVIEW_HIGH_CONFIDENCE=0.90
FISH_AI_REVIEW_MONTHLY_LIMIT_MICROS=50000000
FISH_AI_REVIEW_RESERVATION_TTL_MINUTES=15
FISH_AI_REVIEW_RETENTION_MONTHS=3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENAI_API_KEY=

GITHUB_APP_CLIENT_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=""
